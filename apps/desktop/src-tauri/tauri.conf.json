{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ERAtw-NEXT",
  "version": "0.1.0",
  "identifier": "dev.eratw.next",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ERAtw-NEXT",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
