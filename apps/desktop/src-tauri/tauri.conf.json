{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ERAtw-NEXT",
  "version": "0.1.0",
  "identifier": "dev.eratw-next.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ERAtw-NEXT",
        "width": 1600,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
