{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eratw-next.dev/schemas/save-envelope/v1",
  "title": "Versioned game save envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "saveVersion",
    "engineVersion",
    "dependencies",
    "initialState",
    "state",
    "commandLog",
    "stateHash"
  ],
  "properties": {
    "schemaVersion": { "const": "save-envelope/v1" },
    "saveVersion": { "const": 1 },
    "engineVersion": { "type": "string", "minLength": 1 },
    "dependencies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["packageId", "version"],
        "properties": {
          "packageId": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 }
        }
      }
    },
    "initialState": { "$ref": "https://eratw-next.dev/schemas/game-state/v1" },
    "state": { "$ref": "https://eratw-next.dev/schemas/game-state/v1" },
    "commandLog": {
      "type": "array",
      "items": { "$ref": "https://eratw-next.dev/schemas/game-command/v1" }
    },
    "stateHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}
