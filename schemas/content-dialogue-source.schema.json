{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eratw-next.dev/schemas/content-dialogue-source/v1-draft",
  "title": "ERAtw-NEXT dialogue source draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "legacy",
    "sourcePath",
    "candidateSpeakerRefs",
    "candidateSceneKind",
    "conversionPlan",
    "sourceTrace",
    "review"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^core\\.dialogue_source\\.[a-z0-9_.-]+$" },
    "kind": { "const": "legacy_erb_source" },
    "legacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["characterNumericId", "filePattern", "categoryTokens"],
      "properties": {
        "characterNumericId": { "type": ["integer", "null"], "minimum": 0 },
        "filePattern": { "type": "string", "minLength": 1 },
        "categoryTokens": { "type": "array", "items": { "type": "string" } }
      }
    },
    "sourcePath": { "type": "string", "minLength": 1 },
    "candidateSpeakerRefs": { "type": "array", "items": { "type": "string" } },
    "candidateSceneKind": { "type": "string", "minLength": 1 },
    "conversionPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "requiresErbSubset", "requiresManualReview"],
      "properties": {
        "strategy": { "enum": ["manual_or_subset_erb", "manual_only", "future_new_content"] },
        "requiresErbSubset": { "type": "boolean" },
        "requiresManualReview": { "type": "boolean" }
      }
    },
    "sourceTrace": { "$ref": "#/$defs/sourceTrace" },
    "review": { "$ref": "#/$defs/review" }
  },
  "$defs": {
    "sourceTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceRootId", "relativePath", "conversion"],
      "properties": {
        "sourceRootId": { "const": "eratw-content" },
        "relativePath": { "type": "string", "minLength": 1 },
        "legacyId": { "type": ["string", "null"] },
        "lineRange": { "type": ["array", "null"], "items": { "type": "integer", "minimum": 1 }, "minItems": 2, "maxItems": 2 },
        "contentHash": { "type": ["string", "null"] },
        "conversion": { "$ref": "#/$defs/conversion" }
      }
    },
    "conversion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "version", "confidence", "requiresReview"],
      "properties": {
        "tool": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "confidence": { "enum": ["high", "medium", "low"] },
        "requiresReview": { "type": "boolean" }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "notes", "blockingIssues"],
      "properties": {
        "status": { "enum": ["generated", "needs_review", "accepted", "rejected", "blocked"] },
        "notes": { "type": "array", "items": { "type": "string" } },
        "blockingIssues": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
