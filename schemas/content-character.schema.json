{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eratw-next.dev/schemas/content-character/v1-draft",
  "title": "ERAtw-NEXT character draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "legacy",
    "displayName",
    "profile",
    "dictionaryRefs",
    "resourceRefs",
    "dialogueSourceRefs",
    "sourceTrace",
    "review"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^core\\.character\\.[a-z0-9_.-]+$" },
    "legacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["numericId", "rawKeys"],
      "properties": {
        "numericId": { "type": "integer", "minimum": 0 },
        "rawKeys": { "type": "array", "items": { "type": "string" } }
      }
    },
    "displayName": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "ja", "zhHans", "aliases"],
      "properties": {
        "primary": { "type": "string", "minLength": 1 },
        "ja": { "type": ["string", "null"] },
        "zhHans": { "type": ["string", "null"] },
        "aliases": { "type": "array", "items": { "type": "string" } }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["species", "title", "description"],
      "properties": {
        "species": { "type": ["string", "null"] },
        "title": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] }
      }
    },
    "dictionaryRefs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["talents", "baseStats", "abilities"],
      "properties": {
        "talents": { "type": "array", "items": { "type": "string" } },
        "baseStats": { "type": "array", "items": { "type": "string" } },
        "abilities": { "type": "array", "items": { "type": "string" } }
      }
    },
    "resourceRefs": { "type": "array", "items": { "type": "string" } },
    "dialogueSourceRefs": { "type": "array", "items": { "type": "string" } },
    "sourceTrace": { "$ref": "#/$defs/sourceTrace" },
    "review": { "$ref": "#/$defs/review" }
  },
  "$defs": {
    "sourceTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceRootId", "relativePath", "conversion"],
      "properties": {
        "sourceRootId": { "const": "eratw-content" },
        "relativePath": { "type": "string", "minLength": 1 },
        "legacyId": { "type": ["string", "null"] },
        "lineRange": { "type": ["array", "null"], "items": { "type": "integer", "minimum": 1 }, "minItems": 2, "maxItems": 2 },
        "contentHash": { "type": ["string", "null"] },
        "conversion": { "$ref": "#/$defs/conversion" }
      }
    },
    "conversion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "version", "confidence", "requiresReview"],
      "properties": {
        "tool": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "confidence": { "enum": ["high", "medium", "low"] },
        "requiresReview": { "type": "boolean" }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "notes", "blockingIssues"],
      "properties": {
        "status": { "enum": ["generated", "needs_review", "accepted", "rejected", "blocked"] },
        "notes": { "type": "array", "items": { "type": "string" } },
        "blockingIssues": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
