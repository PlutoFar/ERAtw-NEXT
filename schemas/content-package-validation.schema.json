{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eratw-next.dev/schemas/content-package-validation/v1-draft",
  "title": "ERAtw-NEXT draft package validation report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "valid", "errors", "warnings", "counts"],
  "properties": {
    "schemaVersion": { "const": "content-package-validation/v1-draft" },
    "valid": { "type": "boolean" },
    "errors": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
    "warnings": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
    "counts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    }
  },
  "$defs": {
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "objectId", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["info", "warning", "blocker"] },
        "objectId": { "type": ["string", "null"] },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
