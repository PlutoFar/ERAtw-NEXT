{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eratw-next.dev/schemas/content-package-index/v1",
  "title": "Loaded content package index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "rootPath",
    "package",
    "engineRequirement",
    "capabilities",
    "reviewStatus",
    "playable",
    "counts",
    "characters",
    "locations",
    "resources",
    "warnings"
  ],
  "properties": {
    "schemaVersion": { "const": "content-package-index/v1" },
    "rootPath": { "type": "string", "minLength": 1 },
    "package": { "$ref": "#/$defs/packageIdentity" },
    "engineRequirement": { "type": "string", "minLength": 1 },
    "capabilities": { "type": "array", "items": { "type": "string" } },
    "reviewStatus": { "type": "string", "minLength": 1 },
    "playable": { "type": "boolean" },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dictionaries", "characters", "locations", "resources", "dialogueSources", "dialogueScenes"],
      "properties": {
        "dictionaries": { "type": "integer", "minimum": 0 },
        "characters": { "type": "integer", "minimum": 0 },
        "locations": { "type": "integer", "minimum": 0 },
        "resources": { "type": "integer", "minimum": 0 },
        "dialogueSources": { "type": "integer", "minimum": 0 },
        "dialogueScenes": { "type": "integer", "minimum": 0 }
      }
    },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "displayName", "reviewStatus", "resourceCount", "dialogueSourceCount"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "displayName": { "type": "string", "minLength": 1 },
          "reviewStatus": { "type": "string", "minLength": 1 },
          "resourceCount": { "type": "integer", "minimum": 0 },
          "dialogueSourceCount": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "locations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "displayName", "kind", "tags", "connections", "reviewStatus"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "displayName": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "tags": { "type": "array", "items": { "type": "string" } },
          "connections": { "type": "array", "items": { "type": "string" } },
          "reviewStatus": { "type": "string", "minLength": 1 }
        }
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "mediaType", "sourcePath", "usage", "author", "license", "reviewStatus"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "mediaType": { "type": "string", "minLength": 1 },
          "sourcePath": { "type": "string", "minLength": 1 },
          "usage": { "type": "array", "items": { "type": "string" } },
          "author": { "type": "string" },
          "license": { "type": "string" },
          "reviewStatus": { "type": "string", "minLength": 1 }
        }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "packageIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageId", "displayName", "version"],
      "properties": {
        "packageId": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    }
  }
}
