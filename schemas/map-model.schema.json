{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eratw-next.dev/schemas/map-model/v1",
  "title": "MapModel",
  "description": "map_get_overview 命令返回值契约 (map-model/v1)。双模式地图（字符画 / SVG）共享同一份数据。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "defaultAreaId", "grid", "areas", "legend", "nodes"],
  "properties": {
    "schemaVersion": { "const": "map-model/v1" },
    "defaultAreaId": { "type": "string", "minLength": 1 },
    "grid": {
      "type": "object",
      "description": "逻辑网格尺寸；两种渲染器都按此坐标系定位节点。",
      "additionalProperties": false,
      "required": ["columns", "rows"],
      "properties": {
        "columns": { "type": "integer", "minimum": 1 },
        "rows": { "type": "integer", "minimum": 1 }
      }
    },
    "areas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "description"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        }
      }
    },
    "legend": {
      "type": "array",
      "minItems": 1,
      "description": "占用活动类型图例，比原版更细化（颜色 + 字形 + 文案）。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "label", "glyph", "color"],
        "properties": {
          "key": {
            "type": "string",
            "enum": ["staying", "working", "sleeping", "passing", "free"]
          },
          "label": { "type": "string", "minLength": 1 },
          "glyph": { "type": "string", "minLength": 1 },
          "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "areaId",
          "label",
          "kind",
          "glyph",
          "x",
          "y",
          "terrain",
          "moveMinutes",
          "note",
          "links",
          "occupants"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "areaId": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "kind": {
            "type": "string",
            "enum": ["home", "shop", "shrine", "landmark", "gate", "public", "nature"]
          },
          "glyph": { "type": "string", "minLength": 1 },
          "x": { "type": "integer", "minimum": 0 },
          "y": { "type": "integer", "minimum": 0 },
          "terrain": { "type": "string", "minLength": 1 },
          "moveMinutes": { "type": "integer", "minimum": 0 },
          "note": { "type": "string" },
          "links": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "occupants": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "label", "activity"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "label": { "type": "string", "minLength": 1 },
                "activity": {
                  "type": "string",
                  "enum": ["staying", "working", "sleeping", "passing", "free"]
                }
              }
            }
          }
        }
      }
    }
  }
}
