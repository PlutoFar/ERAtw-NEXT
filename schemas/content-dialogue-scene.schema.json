{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eratw-next.dev/schemas/content-dialogue-scene/v1-draft",
  "title": "ERAtw-NEXT dialogue scene draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "entryNodeId",
    "speakerRefs",
    "resourceRefs",
    "nodes",
    "sourceTrace",
    "review"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^core\\.dialogue\\.scene\\.[a-z0-9_.-]+$" },
    "entryNodeId": { "type": "string", "minLength": 1 },
    "speakerRefs": { "type": "array", "items": { "type": "string" } },
    "resourceRefs": { "type": "array", "items": { "type": "string" } },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "speakerRef", "text", "choices", "effects", "conditions"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "speakerRef": { "type": ["string", "null"] },
          "text": { "type": "string" },
          "choices": { "type": "array" },
          "effects": { "type": "array" },
          "conditions": { "type": "array" }
        }
      }
    },
    "sourceTrace": { "type": "object" },
    "review": {
      "type": "object",
      "required": ["status", "notes", "blockingIssues"],
      "properties": {
        "status": { "enum": ["generated", "needs_review", "accepted", "rejected", "blocked"] },
        "notes": { "type": "array", "items": { "type": "string" } },
        "blockingIssues": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
